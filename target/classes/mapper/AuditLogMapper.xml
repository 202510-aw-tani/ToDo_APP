<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.todo.mapper.AuditLogMapper">

    <insert id="insert" parameterType="com.example.todo.model.AuditLog"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO audit_logs (event_type, detail, actor, created_at)
        VALUES (#{eventType}, #{detail}, #{actor}, #{createdAt})
    </insert>

</mapper>
